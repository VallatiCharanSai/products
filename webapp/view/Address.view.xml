<mvc:View
    controllerName="products.controller.Address"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc">
    <Page
        title="Delivery Address"
        showNavButton="true"
        navButtonPress=".onNavBack">
        <content>
            <VBox class="sapUiMediumMargin" width="100%">
                <Label text="Full Name"/>
                <Input
                    id="nameInput"
                    value="{checkout>/name}"
                    width="100%"
                    placeholder="Enter full name"/>
                <Label
                    text="Phone Number"
                    class="sapUiSmallMarginTop"/>
                <Input
                    id="mobileInput"
                    value="{checkout>/phone}"
                    width="100%"
                    type="Tel"
                    placeholder="Enter phone number"/>
                <Label
                    text="Email"
                    class="sapUiSmallMarginTop"/>
                <Input
                    id="emailInput"
                    value="{checkout>/email}"
                    width="100%"
                    type="Email"
                    placeholder="Enter email"/>
                <Label
                    text="Delivery Address"
                    class="sapUiSmallMarginTop"/>
                <TextArea
                    id="addressInput"
                    value="{checkout>/address}"
                    width="100%"
                    rows="4"
                    placeholder="Enter full delivery address"/>
                <HBox
                    class="sapUiSmallMarginTop"
                    wrap="Wrap"
                    width="100%"
                    justifyContent="SpaceBetween">
                    <VBox
                        width="32%"
                        class="sapUiTinyMarginBottom">
                        <Label text="City"/>
                        <Input
                            id="cityInput"
                            value="{checkout>/city}"
                            width="100%"/>
                    </VBox>
                    <VBox
                        width="32%"
                        class="sapUiTinyMarginBottom">
                        <Label text="State"/>
                        <Input
                            id="stateInput"
                            value="{checkout>/state}"
                            width="100%"/>
                    </VBox>
                    <VBox
                        width="32%"
                        class="sapUiTinyMarginBottom">
                        <Label text="Pincode"/>
                        <Input
                            id="pincodeInput"
                            value="{checkout>/pincode}"
                            width="100%"
                            type="Number"/>
                    </VBox>
                </HBox>
                <Button
                    text="Continue to Payment"
                    type="Emphasized"
                    press=".onContinue"
                    class="sapUiMediumMarginTop"
                    width="100%"/>
            </VBox>
        </content>
    </Page>
</mvc:View>