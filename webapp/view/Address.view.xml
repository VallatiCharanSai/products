<mvc:View
    controllerName="products.controller.Address"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:l="sap.ui.layout">
    <Page
        title="Delivery Address"
        showNavButton="true"
        navButtonPress=".onNavBack">
        <content>
            <VBox class="sapUiMediumMargin">
                <Label text="Full Name"/>
                <Input
                    id="fullName"
                    placeholder="Enter full name"
                    width="100%"/>
                <Label
                    text="Phone Number"
                    class="sapUiSmallMarginTop"/>
                <Input
                    id="phone"
                    type="Tel"
                    placeholder="Enter phone number"
                    width="100%"/>
                <Label
                    text="Email"
                    class="sapUiSmallMarginTop"/>
                <Input
                    id="email"
                    type="Email"
                    placeholder="Enter email"
                    width="100%"/>
                <Label
                    text="Delivery Address"
                    class="sapUiSmallMarginTop"/>
                <TextArea
                    id="address"
                    rows="4"
                    placeholder="Enter delivery address"
                    width="100%"/>
                <l:Grid
                    defaultSpan="XL4 L4 M4 S12"
                    width="100%"
                    class="sapUiMediumMarginTop">
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="City"/>
                        <Input
                            id="city"
                            width="100%"/>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="State"/>
                        <Input
                            id="state"
                            width="100%"/>
                    </VBox>
                    <VBox>
                        <Label text="Pincode"/>
                        <Input
                            id="pincode"
                            width="100%"/>
                    </VBox>
                </l:Grid>
                <Button
                    text="Continue to Payment"
                    type="Emphasized"
                    class="sapUiLargeMarginTop"
                    press=".onContinue"/>
            </VBox>
        </content>
    </Page>
</mvc:View>