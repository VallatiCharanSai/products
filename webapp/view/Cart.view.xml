<mvc:View
    controllerName="products.controller.Cart"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core">
    <Page
        title="Cart"
        showNavButton="true"
        navButtonPress=".onNavBack">
        <footer>
            <Toolbar>
                <ToolbarSpacer/>
                <Button
                    text="Buy Now"
                    type="Emphasized"
                    press=".onBuyNow"/>
                <Button
                    text="Clear Cart"
                    type="Reject"
                    press=".onClearCart"/>
            </Toolbar>
        </footer>
        <content>
            <VBox
                visible="{= ${cart>/items}.length === 0 }"
                alignItems="Center"
                justifyContent="Center"
                width="100%"
                class="sapUiLargeMarginTop">
                <core:Icon
                    src="sap-icon://cart"
                    size="5rem"
                    color="#b0b7c3"
                    class="sapUiLargeMarginBottom"/>
                <Title
                    text="Your Cart is Empty"
                    level="H1"
                    class="sapUiSmallMarginBottom"/>
                <Text
                    text="Browse products and add them to your cart"
                    class="sapUiSmallMarginBottom"/>
                <Button
                    text="Continue Shopping"
                    type="Emphasized"
                    press=".onContinueShopping"/>
            </VBox>
            <List
                visible="{= ${cart>/items}.length > 0 }"
                items="{cart>/items}">
                <items>
                    <CustomListItem>
                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            width="100%">
                            <VBox>
                                <Title
                                    text="{cart>ProductName}"
                                    level="H4"/>
                                <Text
                                    text="Price: {cart>UnitPrice} USD"/>
                                <Text
                                    text="Available Stock: {cart>UnitsInStock}"/>
                                <Text
                                    text="Quantity: {cart>Quantity}"/>
                                <Text
                                    text="Total: {
                                        path: 'cart>',
                                        formatter: '.formatItemTotal'
                                    }"/>
                            </VBox>
                            <VBox alignItems="End">
                                <HBox alignItems="Center">
                                    <Button
                                        text="-"
                                        press=".onDecreaseQuantity"/>
                                    <Text
                                        text="{cart>Quantity}"
                                        class="sapUiSmallMarginBegin sapUiSmallMarginEnd"/>
                                    <Button
                                        text="+"
                                        press=".onIncreaseQuantity"
                                        enabled="{
                                            parts: [
                                                'cart>Quantity',
                                                'cart>UnitsInStock'
                                            ],
                                            formatter: '.isIncreaseEnabled'
                                        }"/>
                                </HBox>
                                <Button
                                    text="Remove"
                                    type="Reject"
                                    class="sapUiSmallMarginTop"
                                    press=".onRemoveItem"/>
                            </VBox>
                        </HBox>
                    </CustomListItem>
                </items>
            </List>
            <VBox
                visible="{= ${cart>/items}.length > 0 }"
                class="sapUiLargeMargin">
                <Title
                    text="Order Summary"
                    level="H2"
                    class="sapUiMediumMarginBottom"/>
                <Text
                    text="Subtotal: {cart>/subtotal} USD"
                    class="sapUiSmallMarginBottom"/>
                <Text
                    text="{cart>/discountText}"
                    class="sapUiSmallMarginBottom"/>
                <Text
                    text="Discount Amount: {cart>/discount} USD"
                    class="sapUiSmallMarginBottom"/>
                <Title
                    text="Final Total: {cart>/finalTotal} USD"
                    level="H2"
                    class="sapUiSmallMarginTop"/>
            </VBox>
        </content>
    </Page>
</mvc:View>