{
  "name": "products",
  "version": "0.0.1",
  "description": "An SAP Fiori application.",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "devDependencies": {
    "@sap-ux/eslint-plugin-fiori-tools": "^9.0.0",
    "@sap-ux/ui5-middleware-fe-mockserver": "2",
    "@sap/ux-specification": "^1.144.2",
    "@sap/ux-ui5-tooling": "^1.23.0",
    "@ui5/cli": "^4.0.33",
    "eslint": "^9"
  },
  "scripts": {
    "start": "ui5 serve --open test/flp.html",
    "start-local": "ui5 serve --config ./ui5-local.yaml --open test/flp.html",
    "build": "ui5 build --config=ui5.yaml --clean-dest --dest dist",
    "lint": "eslint ./",
    "start-noflp": "ui5 serve --open index.html",
    "start-mock": "ui5 serve --config ./ui5-mock.yaml --open test/flp.html",
    "int-test": "ui5 serve --config ./ui5-mock.yaml --open test/integration/opaTests.qunit.html",
    "start-variants-management": "ui5 serve --open preview.html",
    "unit-test": "ui5 serve --config ./ui5-mock.yaml --open test/unit/unitTests.qunit.html"
  },
  "sapuxLayer": "CUSTOMER_BASE"
}